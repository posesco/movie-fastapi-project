# Super user
ADMIN_USER=someone
ADMIN_EMAIL=some@nobody.com
ADMIN_PASS=my_pass

# JWT
SECRET_KEY=this_is_my_secret
ALGORITHM = HS256
ACCESS_TOKEN_EXPIRE_MINUTES = 15

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=devdb
POSTGRES_USER=admin
POSTGRES_PASSWORD=nimda
DATABASE_URL=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
ASYNC_DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Settings
API_VERSION=v1.2.2
PROJECT_MODE=debug
PROJECT_TITLE= Movie API with FastApi
PROJECT_VERSION=1.2.2
PROJECT_DESC=Project with FastAPI.
PROJECT_DEBUG_MODE=True

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# Security
# Use a JSON list for origins in .env (Pydantic style)
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://milocal.com", "http://127.0.0.1:3000"]
ALLOWED_HOSTS=["localhost", "127.0.0.1", "milocal.com", "*.milocal.com"]

# Observability
OTEL_ENABLED=False
OTEL_COLLECTOR_ENDPOINT=http://alloy:4317
OTEL_SERVICE_NAME=fastapi-app
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=dev,service.version=${PROJECT_VERSION}

# Telegram Alerts
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# S3 / Object Storage
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=fastapi-bucket
S3_REGION=us-east-1
S3_USE_SSL=False
S3_PUBLIC_URL=http://localhost:9000

# Storage (SOLID/OCP)
STORAGE_BACKEND=s3 # Options: s3, local
LOCAL_STORAGE_PATH=uploads

# SonarQube
SONAR_TOKEN=your_sonarqube_token_here
SONAR_DB_PASSWORD=sonar