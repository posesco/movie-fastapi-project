// --- TRACING (OpenTelemetry) ---

// Receptor OTLP (recibe datos de la app)
otelcol.receiver.otlp "otlp_receiver" {
  grpc {
    endpoint = "0.0.0.0:4317"
  }
  http {
    endpoint = "0.0.0.0:4318"
  }

  output {
    metrics = [otelcol.exporter.prometheus.to_prometheus.input]
    traces  = [otelcol.exporter.otlp.tempo.input]
    logs    = [otelcol.exporter.loki.to_loki.input]
  }
}

// Convertidor de OTLP a Loki
otelcol.exporter.loki "to_loki" {
  forward_to = [loki.write.local.receiver]
}

// Convertidor de OTLP a Prometheus
otelcol.exporter.prometheus "to_prometheus" {
  forward_to = [prometheus.remote_write.local.receiver]
}

// Exportador a Tempo
otelcol.exporter.otlp "tempo" {
  client {
    endpoint = env("ALLOY_OTLP_UPSTREAM")
    tls {
			insecure = true
		}
  }
}

