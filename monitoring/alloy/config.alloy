livedebugging {
	enabled = true
}

// --- LOGS (OTEL) ---
// Configuración simplificada: todo entra por OTLP
// Send metrics to local Loki instance via  write.
loki.write "local" {
  endpoint {
    url = "http://loki:3100/loki/api/v1/push"
  }
}
// Send metrics to the local Prometheus instance via remote write.
prometheus.remote_write "local" {
	endpoint {
		url = "http://prometheus:9090/api/v1/write"
	}
}

// Expose PostgreSQL metrics using the built-in postgres exporter.

